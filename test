# ---------------------------------------------------------------------------
# Tokenizer tests
# ---------------------------------------------------------------------------
def test_tokenizer_plain():
    """
    Test the plain Tokenizer class against a small hand-written corpus.
    The corpus contains:
    - Trailing punctuation that should be stripped ("Wow!!!", "didn't.").
    - Internal punctuation that should be kept ("didn't").
    - Quotes around a sentence that should be stripped.
    - Extra whitespace that should be collapsed.
    @return: bool: True if Tokenizer.string2sentences produces the
             expected output, False otherwise (with a diagnostic printed).
    """
    corpus = "Hello, world! I didn't expect that.  \"Wow!!!\"\n"
    expected = [
        ["Hello", "world"],
        ["I", "didn't", "expect", "that"],
        ["Wow"],
    ]
    tokenizer = Tokenizer()
    actual = tokenizer.string2sentences(corpus)
    if actual == expected:
        return True
    # Print a side-by-side comparison so the failure is easy to debug.
    print("test_tokenizer_plain FAILED")
    print(f"  input:    {corpus!r}")
    print(f"  expected: {expected}")
    print(f"  actual:   {actual}")
    if len(actual) != len(expected):
        print(f"  -> sentence count differs: "
              f"expected {len(expected)}, got {len(actual)}")
    else:
        for i, (exp, act) in enumerate(zip(expected, actual)):
            if exp != act:
                print(f"  -> sentence {i} differs:")
                print(f"       expected: {exp}")
                print(f"       actual:   {act}")
    return False
def test_tokenize_nltk():
    """
    Test the TokenizerNLTK class on the same tiny corpus used by
    test_tokenizer_plain.
    NLTK splits contractions, so "didn't" becomes two tokens: "did"
    and "n't". The expected output reflects that difference, but the
    overall structure (a list of lists of strings) and the sentence
    boundaries should still match.
    @return: bool: True if TokenizerNLTK.string2sentences produces the
             expected output, False otherwise (with a diagnostic printed).
    """
    corpus = "Hello, world! I didn't expect that.  \"Wow!!!\"\n"
    # NLTK keeps the apostrophe-led "n't" as a separate token.
    # Pure-punctuation tokens like "," and "''" are dropped by our
    # TokenizerNLTK.word_tokenize implementation.
    expected = [
        ["Hello", "world"],
        ["I", "did", "n't", "expect", "that"],
        ["Wow"],
    ]
    try:
        tokenizer = TokenizerNLTK()
    except Exception as e:
        print(f"test_tokenize_nltk SKIPPED NLTK unavailable: {e}")
        return False
    actual = tokenizer.string2sentences(corpus)
    if actual == expected:
        return True
    print("test_tokenize_nltk FAILED")
    print(f"  input:    {corpus!r}")
    print(f"  expected: {expected}")
    print(f"  actual:   {actual}")
    if len(actual) != len(expected):
        print(f"  -> sentence count differs: "
              f"expected {len(expected)}, got {len(actual)}")
    else:
        for i, (exp, act) in enumerate(zip(expected, actual)):
            if exp != act:
                print(f"  -> sentence {i} differs:")
                print(f"       expected: {exp}")
                print(f"       actual:   {act}")
    return False
