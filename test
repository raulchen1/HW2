# NGramModel tests
# ---------------------------------------------------------------------------
def _build_tiny_trigram_model():
    """
    Build a small trigram model used by both test_ngram_table and
    test_probability_zero.
    The corpus is two short sentences sharing some vocabulary so that
    at least one prefix has more than one successor:
        "I love cats"
        "I love dogs"
    After preprocessing each sentence becomes:
        [<s>, <s>, i, love, cats, </s>]
        [<s>, <s>, i, love, dogs, </s>]
    @return: NGramModel: a trigram (n=3) model in sentence mode.
    """
    sents = [
        ["I", "love", "cats"],
        ["I", "love", "dogs"],
    ]
    return NGramModel(sents, n=3, tokenizer=Tokenizer(), mode="sentence")
def test_ngram_table():
    """
    Initialise a trigram model on a tiny hand-written corpus and
    compare the resulting ngram_table to a hand-written gold dict.
    Walking through the two preprocessed sentences:
        (<s>, <s>) -> i      [twice]
        (<s>, i)   -> love   [twice]
        (i, love)  -> cats   [once]
        (i, love)  -> dogs   [once]
        (love, cats) -> </s> [once]
        (love, dogs) -> </s> [once]
    @return: bool: True if the model's ngram_table matches the gold
        dict, False otherwise (with a diagnostic printed).
    """
    model = _build_tiny_trigram_model()
    expected = {
        (START, START): {"i": 2},
        (START, "i"): {"love": 2},
        ("i", "love"): {"cats": 1, "dogs": 1},
        ("love", "cats"): {END: 1},
        ("love", "dogs"): {END: 1},
    }
    actual = model.ngram_table
    if actual == expected:
        return True
    print("test_ngram_table FAILED")
    print(f"  expected keys: {sorted(expected.keys())}")
    print(f"  actual keys:   {sorted(actual.keys())}")
    missing = set(expected) - set(actual)
    extra = set(actual) - set(expected)
    if missing:
        print(f"  -> missing prefixes: {missing}")
    if extra:
        print(f"  -> unexpected prefixes: {extra}")
    # Compare successor dicts for every prefix that appears in both.
    for prefix in set(expected) & set(actual):
        if expected[prefix] != actual[prefix]:
            print(f"  -> successors differ for prefix {prefix}:")
            print(f"       expected: {expected[prefix]}")
            print(f"       actual:   {actual[prefix]}")
    return False
def test_probability_zero():
    """
    Test the four required zero/non-zero probability cases against the
    tiny trigram model from _build_tiny_trigram_model.
    Cases:
      A. Prefix not in the model at all:
         A1) raw probability == 0
         A2) smoothed probability == 0
            (we don't know the prefix's total count, so smoothing
             can't produce a meaningful estimate)
      B. Successor not in the vocabulary at all:
         B1) raw probability == 0
         B2) smoothed probability == 0
            (smoothing does not extend the vocabulary)
      C. Prefix in the model, successor in the vocabulary but never
         observed after this prefix:
         C1) raw probability == 0
         C2) smoothed probability > 0
    @return: bool: True if every case behaves as expected, False
        otherwise (with a diagnostic printed for each mismatch).
    """
    model = _build_tiny_trigram_model()
    k = 1  # LaPlace smoothing constant
    # Use a small struct of (label, condition, detail) so we can collect
    # every failure instead of stopping at the first one.
    checks = []
    # --- A. Unknown prefix ---
    unknown_prefix = ("nobody", "knows")
    known_successor = "cats"  # is in the vocab
    p_a_raw = model.probability(unknown_prefix, known_successor, 0)
    p_a_smooth = model.probability(unknown_prefix, known_successor, k)
    checks.append((
        "A1 raw prob for unknown prefix is 0",
        p_a_raw == 0,
        f"got {p_a_raw}",
    ))
    checks.append((
        "A2 smoothed prob for unknown prefix is 0",
        p_a_smooth == 0,
        f"got {p_a_smooth}",
    ))
    # --- B. Unknown successor ---
    known_prefix = ("i", "love")
    unknown_successor = "zebras"  # not anywhere in the training data
    p_b_raw = model.probability(known_prefix, unknown_successor, 0)
    p_b_smooth = model.probability(known_prefix, unknown_successor, k)
    checks.append((
        "B1 raw prob for unknown successor is 0",
        p_b_raw == 0,
        f"got {p_b_raw}",
    ))
    checks.append((
        "B2 smoothed prob for unknown successor is 0",
        p_b_smooth == 0,
        f"got {p_b_smooth}",
    ))
    # --- C. Known prefix, known successor, but not seen together ---
    # ("love", "cats") is a known prefix, and "dogs" is in the vocab
    # (it follows ("i", "love")), but "dogs" has never followed
    # ("love", "cats") -- only </s> did.
    seen_prefix = ("love", "cats")
    unseen_successor = "dogs"
    # Sanity-check that the test setup is what we think it is. If
    # these invariants don't hold the test would silently pass for
    # the wrong reason.
    assert seen_prefix in model.ngram_table, \
        "test setup: prefix should be known"
    assert unseen_successor in model.successors, \
        "test setup: successor should be in vocabulary"
    assert unseen_successor not in model.ngram_table[seen_prefix], \
        "test setup: successor should not follow this prefix"
    p_c_raw = model.probability(seen_prefix, unseen_successor, 0)
    p_c_smooth = model.probability(seen_prefix, unseen_successor, k)
    checks.append((
        "C1 raw prob for known prefix + in-vocab unseen successor is 0",
        p_c_raw == 0,
        f"got {p_c_raw}",
    ))
    checks.append((
        "C2 smoothed prob for known prefix + in-vocab unseen successor > 0",
        p_c_smooth > 0,
        f"got {p_c_smooth}",
    ))
    failures = [(label, detail) for label, ok, detail in checks if not ok]
    if not failures:
        return True
    print("test_probability_zero FAILED")
    for label, detail in failures:
        print(f"  -> {label}: {detail}")
    return False
